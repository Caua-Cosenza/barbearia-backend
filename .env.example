# NEVER commit this file with real values
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

DATABASE_URL=postgresql://user:password@localhost:5432/barbeiro_db

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_another_32_chars_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_random_key

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# VAPID keys for Web Push notifications — generate with:
# node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY="sua-chave-publica-vapid"
VAPID_PRIVATE_KEY="sua-chave-privada-vapid"

# Evolution API (WhatsApp) — optional, messages are skipped if not set
EVOLUTION_API_URL="https://sua-evolution-api.railway.app"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE_NAME="barbearia"
BARBER_PHONE="5511999999999"
